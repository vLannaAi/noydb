{
  "name": "@noy-db/to-browser-idb",
  "version": "0.11.0",
  "description": "IndexedDB adapter for noy-db with optional key obfuscation",
  "license": "MIT",
  "author": "vLannaAi <vicio@lanna.ai>",
  "homepage": "https://github.com/vLannaAi/noy-db/tree/main/packages/store-browser-idb#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/vLannaAi/noy-db.git",
    "directory": "packages/to-browser-idb"
  },
  "bugs": {
    "url": "https://github.com/vLannaAi/noy-db/issues"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@noy-db/hub": "workspace:*"
  },
  "devDependencies": {
    "@noy-db/hub": "workspace:*",
    "@noy-db/test-adapter-conformance": "workspace:*",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^18.0.0"
  },
  "keywords": [
    "noy-db",
    "adapter",
    "browser",
    "indexeddb",
    "web",
    "offline-first",
    "encryption",
    "zero-knowledge",
    "obfuscation"
  ]
}
