{
  "name": "@noy-db/to-aws-dynamo",
  "version": "0.11.0",
  "description": "AWS DynamoDB adapter for noy-db — single-table design, zero-knowledge cloud sync",
  "license": "MIT",
  "author": "vLannaAi <vicio@lanna.ai>",
  "homepage": "https://github.com/vLannaAi/noy-db/tree/main/packages/store-aws-dynamo#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/vLannaAi/noy-db.git",
    "directory": "packages/to-aws-dynamo"
  },
  "bugs": {
    "url": "https://github.com/vLannaAi/noy-db/issues"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@noy-db/hub": "workspace:*",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0"
  },
  "devDependencies": {
    "@noy-db/hub": "workspace:*",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0"
  },
  "keywords": [
    "noy-db",
    "adapter",
    "dynamodb",
    "aws",
    "single-table",
    "cloud",
    "sync",
    "encryption",
    "zero-knowledge"
  ]
}
