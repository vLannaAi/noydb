{
  "name": "@noy-db/vue",
  "version": "2.0.0",
  "description": "Vue 3 / Nuxt composables for noy-db — reactive useNoydb, useCollection, useSync, and biometric plugin",
  "license": "MIT",
  "author": "vLannaAi <vicio@lanna.ai>",
  "homepage": "https://github.com/vLannaAi/noy-db/tree/main/packages/vue#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/vLannaAi/noy-db.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/vLannaAi/noy-db/issues"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@noy-db/core": "workspace:*",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@noy-db/core": "workspace:*",
    "vue": "^3.5.32"
  },
  "keywords": [
    "noy-db",
    "vue",
    "vue3",
    "nuxt",
    "composables",
    "reactive",
    "encryption",
    "offline-first",
    "biometric",
    "webauthn"
  ]
}
