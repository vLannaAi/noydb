{
  "name": "@noy-db/core",
  "version": "0.1.0",
  "description": "Zero-knowledge, offline-first, encrypted document store",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vLannaAi/noydb.git",
    "directory": "packages/core"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  },
  "keywords": [
    "encryption",
    "zero-knowledge",
    "offline-first",
    "document-store",
    "aes-256-gcm",
    "web-crypto"
  ]
}
